# ═══════════════════════════════════════════════════════════════
#  FaceSwap AI — Environment Variables
#  Copy to .env and customize:  cp .env.example .env
#  All vars prefixed with FACESWAP_
# ═══════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────
FACESWAP_HOST=0.0.0.0
FACESWAP_PORT=8000
FACESWAP_WEBSOCKET_PATH=/ws/swap
FACESWAP_DOMAIN=localhost

# ── Models ────────────────────────────────────────────────────
FACESWAP_INSWAPPER_MODEL_PATH=models/inswapper_128.onnx
FACESWAP_DETECTOR_MODEL=buffalo_l
FACESWAP_GFPGAN_MODEL_PATH=models/GFPGANv1.4.pth

# ── Processing ────────────────────────────────────────────────
FACESWAP_ENABLE_ENHANCER=false
FACESWAP_FACE_DETECTION_SIZE=640
FACESWAP_SWAP_DET_THRESHOLD=0.5
FACESWAP_JPEG_QUALITY=85

# ── Enhancement ───────────────────────────────────────────────
FACESWAP_ENHANCEMENT_MODE=balanced

# ── Virtual Camera (OBS) ─────────────────────────────────────
FACESWAP_VC_ENABLED=false
FACESWAP_VC_RESOLUTION=720p
FACESWAP_VC_FPS=30

# ── Face Tracking ─────────────────────────────────────────────
FACESWAP_TRACKING_DETECTION_INTERVAL=5
FACESWAP_TRACKING_MAX_MISSED=10

# ── GPU / ONNX ────────────────────────────────────────────────
FACESWAP_GPU_DEVICE_ID=0
FACESWAP_GPU_MEM_LIMIT_MB=4096
FACESWAP_ENABLE_TENSORRT=true
FACESWAP_ENABLE_FP16=true
FACESWAP_ENABLE_CUDA_GRAPH=true
FACESWAP_ENABLE_PINNED_MEMORY=true
FACESWAP_CUDNN_EXHAUSTIVE=false
FACESWAP_TRT_WORKSPACE_MB=2048

# ── Voice / Audio ─────────────────────────────────────────────
FACESWAP_VOICE_WEBSOCKET_PATH=/ws/voice
FACESWAP_VOICE_ENABLED=false
FACESWAP_VOICE_SAMPLE_RATE=24000
FACESWAP_VOICE_CHUNK_DURATION_MS=20
FACESWAP_VOICE_CHANNELS=1
FACESWAP_VOICE_INPUT_DEVICE=-1

# Noise suppression
FACESWAP_VOICE_NOISE_SUPPRESSION=true
FACESWAP_VOICE_NOISE_AGGRESSIVENESS=2

# Voice conversion
FACESWAP_VOICE_CONVERSION_ENABLED=false
FACESWAP_VOICE_MODEL_PATH=
FACESWAP_VOICE_PITCH_SHIFT=0

# Echo cancellation
FACESWAP_VOICE_ECHO_CANCELLATION=true
FACESWAP_VOICE_ECHO_TAIL_LENGTH_MS=128

# Mute
FACESWAP_VOICE_MUTED=false

# ── Platform Integrations ─────────────────────────────────────
FACESWAP_PLATFORM_DEFAULT_SAMPLE_RATE=48000
FACESWAP_PLATFORM_DEFAULT_CHANNELS=1

# Zoom
FACESWAP_PLATFORM_ZOOM_ENABLED=false
FACESWAP_PLATFORM_ZOOM_SDK_KEY=

# Google Meet
FACESWAP_PLATFORM_MEET_ENABLED=false

# Discord
FACESWAP_PLATFORM_DISCORD_ENABLED=false
FACESWAP_PLATFORM_DISCORD_TOKEN=

# Telegram
FACESWAP_PLATFORM_TELEGRAM_ENABLED=false
FACESWAP_PLATFORM_TELEGRAM_BOT_TOKEN=

# OBS
FACESWAP_PLATFORM_OBS_ENABLED=false

# WebRTC
FACESWAP_PLATFORM_WEBRTC_ENABLED=false
FACESWAP_PLATFORM_WEBRTC_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]

# ── CORS ──────────────────────────────────────────────────────
FACESWAP_CORS_ORIGINS=["*"]

# ── Logging ───────────────────────────────────────────────────
FACESWAP_LOG_LEVEL=INFO

# ── GPU Monitor ───────────────────────────────────────────────
GPU_MONITOR_INTERVAL=5